generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountLifecycleState {
  ACTIVE
  TRIALING
  GRACE
  CANCELED
  LOCKED
}

enum BillingProvider {
  STRIPE
}

enum SubscriptionPlan {
  FREE
  PRO
  FAMILY
  TEAMS
}

enum GroupType {
  FAMILY
  TEAM
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum GroupInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  EXPIRED
}

enum SubscriptionInterval {
  MONTHLY
  YEARLY
}

enum ImportExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ContactImportFormat {
  CSV_GENERIC
}

enum ContactExportFormat {
  CSV_GENERIC
  VCARD_4
}

enum ImportSourceProfile {
  GENERIC
  GOOGLE
  APPLE
  OUTLOOK
}

enum MergeSuggestionStatus {
  OPEN
  DISMISSED
  MERGED
  STALE
}

enum MergeSuggestionConfidence {
  HIGH
  MEDIUM
  LOW
}

enum MergeDecisionStatus {
  ACCEPTED
  REJECTED
  REVERSED
}

enum SyncProvider {
  CARDDAV
}

enum SyncDirection {
  TWO_WAY
  IMPORT_ONLY
  EXPORT_ONLY
}

enum SyncAccountStatus {
  ACTIVE
  PAUSED
  NEEDS_REAUTH
  ERROR
}

enum SyncJobTrigger {
  MANUAL
  SCHEDULED
  WEBHOOK
  RECOVERY
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

enum SyncConflictType {
  LOCAL_REMOTE_MUTATION
  DELETE_CONFLICT
  MERGE_CONFLICT
  VERSION_MISMATCH
}

enum SyncConflictStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum SyncConflictSource {
  OUTBOUND_SYNC
  INBOUND_DEVICE
}

enum SyncResolutionStrategy {
  KEEP_LOCAL
  KEEP_REMOTE
  DUPLICATE_LOCAL
  ARCHIVE_LOCAL
  MANUAL_MERGE
}

enum SourceType {
  MANUAL
  IMPORT_CSV
  SYNC_CARDDAV
  SHARED_STATIC
  SHARED_LIVE
  API
}

model User {
  id                    String                @id @default(cuid())
  name                  String?
  email                 String                @unique
  password              String
  lifecycleState        AccountLifecycleState @default(ACTIVE)
  autoFillPhoneticNames Boolean               @default(false)
  appPasswords          AppPassword[]
  contacts              Contact[]
  importJobs            ImportJob[]
  exportJobs            ExportJob[]
  mergeSuggestions      MergeSuggestion[]
  mergeDecisions        MergeDecision[]
  syncAccounts          SyncAccount[]
  subscriptionCustomer  SubscriptionCustomer?
  subscriptions         Subscription[]
  activityEvents        ActivityEvent[]
  ownedGroups           Group[]               @relation("GroupOwner")
  groupMemberships      GroupMember[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model AppPassword {
  id             String         @id @default(cuid())
  userId         String
  label          String
  hashedPassword String
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncConflicts  SyncConflict[]

  @@index([userId, revokedAt, createdAt])
  @@index([userId, revokedAt])
}

model Contact {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  importJobId           String?
  importJob             ImportJob?        @relation(fields: [importJobId], references: [id], onDelete: SetNull)
  leftMergeSuggestions  MergeSuggestion[] @relation("MergeSuggestionLeftContact")
  rightMergeSuggestions MergeSuggestion[] @relation("MergeSuggestionRightContact")
  syncLinks             SyncContactLink[]
  syncConflicts         SyncConflict[]
  activityEvents        ActivityEvent[]
  mergedIntoContactId   String?
  mergedIntoContact     Contact?          @relation("ContactMergeLineage", fields: [mergedIntoContactId], references: [id], onDelete: SetNull)
  mergedChildren        Contact[]         @relation("ContactMergeLineage")
  syncUid               String            @unique @default(cuid())
  syncVersion           Int               @default(1)
  syncTombstoneAt       DateTime?
  fullName              String
  firstName             String?
  middleName            String?
  lastName              String?
  phoneticFirstName     String?
  phoneticLastName      String?
  namePrefix            String?
  nameSuffix            String?
  nickname              String?
  email                 String?
  phone                 String?
  company               String?
  phoneticCompany       String?
  jobTitle              String?
  website               String?
  birthday              String?
  address               String?
  avatarUrl             String?
  isFavorite            Boolean           @default(false)
  labels                Json?
  websiteEntries        Json?
  emailAddresses        Json?
  phoneNumbers          Json?
  postalAddresses       Json?
  emailEntries          Json?
  phoneEntries          Json?
  addressEntries        Json?
  significantDates      Json?
  relatedPeople         Json?
  customFields          Json?
  notes                 String?
  sourceType            SourceType        @default(MANUAL)
  sourceDetail          String?
  lastMutatedBy         SourceType        @default(MANUAL)
  lastMutatedByDetail   String?
  archivedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([userId, archivedAt, fullName])
  @@index([userId, archivedAt, nickname])
  @@index([userId, archivedAt, email])
  @@index([userId, archivedAt, phone])
  @@index([userId, importJobId])
  @@index([userId, syncUid])
  @@index([userId, mergedIntoContactId])
}

model SubscriptionCustomer {
  id                 String          @id @default(cuid())
  userId             String          @unique
  provider           BillingProvider @default(STRIPE)
  providerCustomerId String
  billingEmail       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions      Subscription[]

  @@unique([provider, providerCustomerId])
}

model Subscription {
  id                       String               @id @default(cuid())
  userId                   String
  subscriptionCustomerId   String
  provider                 BillingProvider      @default(STRIPE)
  providerSubscriptionId   String
  plan                     SubscriptionPlan     @default(FREE)
  status                   SubscriptionStatus   @default(TRIALING)
  interval                 SubscriptionInterval @default(MONTHLY)
  contactsLimit            Int?
  monthlyImportLimit       Int?
  syncAccountsLimit        Int?
  appPasswordsLimit        Int?
  advancedMergeEnabled     Boolean              @default(false)
  premiumExportEnabled     Boolean              @default(false)
  cardDavSyncEnabled       Boolean              @default(false)
  familyGroupEnabled       Boolean              @default(false)
  teamsEnabled             Boolean              @default(false)
  sharedAddressBooksLimit  Int?
  memberSlotsLimit         Int?
  activityLogRetentionDays Int?
  liveShareEnabled         Boolean              @default(false)
  staticShareEnabled       Boolean              @default(false)
  startedAt                DateTime             @default(now())
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  trialEndsAt              DateTime?
  graceEndsAt              DateTime?
  cancelAtPeriodEnd        Boolean              @default(false)
  canceledAt               DateTime?
  endedAt                  DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  user                     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionCustomer     SubscriptionCustomer @relation(fields: [subscriptionCustomerId], references: [id], onDelete: Cascade)
  groups                   Group[]

  @@unique([provider, providerSubscriptionId])
  @@index([userId, status])
  @@index([subscriptionCustomerId, status])
}

model ImportJob {
  id                  String                @id @default(cuid())
  userId              String
  format              ContactImportFormat
  sourceProfile       ImportSourceProfile?
  status              ImportExportJobStatus @default(PENDING)
  sourceFileName      String?
  sourceFileSizeBytes Int?
  rowCount            Int                   @default(0)
  previewContactCount Int                   @default(0)
  importedCount       Int                   @default(0)
  skippedCount        Int                   @default(0)
  errorCount          Int                   @default(0)
  warningCount        Int                   @default(0)
  rolledBackCount     Int                   @default(0)
  errorSummary        String?
  previewedAt         DateTime?
  committedAt         DateTime?
  rolledBackAt        DateTime?
  createdAt           DateTime              @default(now())
  startedAt           DateTime              @default(now())
  completedAt         DateTime?
  updatedAt           DateTime              @updatedAt
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts            Contact[]

  @@index([userId, status, createdAt])
}

model ExportJob {
  id              String                @id @default(cuid())
  userId          String
  format          ContactExportFormat
  status          ImportExportJobStatus @default(PENDING)
  includeArchived Boolean               @default(false)
  filterQuery     String?
  resultFileName  String?
  exportedCount   Int                   @default(0)
  errorSummary    String?
  createdAt       DateTime              @default(now())
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model MergeSuggestion {
  id             String                    @id @default(cuid())
  userId         String
  leftContactId  String
  rightContactId String
  pairKey        String
  status         MergeSuggestionStatus     @default(OPEN)
  confidence     MergeSuggestionConfidence
  score          Int
  hardMatch      Boolean                   @default(false)
  signals        Json
  reasons        Json
  source         String
  generatedAt    DateTime                  @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leftContact    Contact                   @relation("MergeSuggestionLeftContact", fields: [leftContactId], references: [id], onDelete: Cascade)
  rightContact   Contact                   @relation("MergeSuggestionRightContact", fields: [rightContactId], references: [id], onDelete: Cascade)
  decisions      MergeDecision[]

  @@unique([userId, pairKey])
  @@index([userId, status, updatedAt])
}

model MergeDecision {
  id             String              @id @default(cuid())
  suggestionId   String
  userId         String
  status         MergeDecisionStatus
  source         String
  notes          String?
  details        Json?
  decidedAt      DateTime            @default(now())
  reversedAt     DateTime?
  reversalSource String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  suggestion     MergeSuggestion     @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, decidedAt])
  @@index([suggestionId, decidedAt])
}

model SyncAccount {
  id                        String            @id @default(cuid())
  userId                    String
  provider                  SyncProvider      @default(CARDDAV)
  status                    SyncAccountStatus @default(PAUSED)
  syncDirection             SyncDirection     @default(TWO_WAY)
  label                     String
  baseUrl                   String
  principalUrl              String?
  addressBookUrl            String?
  addressBookDisplayName    String?
  remoteAccountId           String?
  remoteCTag                String?
  credentialReference       String?
  credentialVersion         Int               @default(1)
  credentialUpdatedAt       DateTime?
  credentialLastValidatedAt DateTime?
  credentialRevokedAt       DateTime?
  encryptionKeyRef          String?
  connectionValidatedAt     DateTime?
  lastSyncCursor            String?
  lastSyncedAt              DateTime?
  lastSucceededAt           DateTime?
  lastErrorAt               DateTime?
  lastErrorCode             String?
  lastErrorMessage          String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  user                      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLinks                 SyncContactLink[]
  syncJobs                  SyncJob[]
  syncConflicts             SyncConflict[]

  @@unique([userId, baseUrl, label])
  @@index([userId, status, updatedAt])
}

model SyncContactLink {
  id               String         @id @default(cuid())
  syncAccountId    String
  contactId        String
  remoteHref       String?
  remoteUid        String?
  remoteETag       String?
  lastSyncedAt     DateTime?
  tombstonedAt     DateTime?
  remoteDeletedAt  DateTime?
  lastErrorCode    String?
  lastErrorMessage String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  syncAccount      SyncAccount    @relation(fields: [syncAccountId], references: [id], onDelete: Cascade)
  contact          Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  syncConflicts    SyncConflict[]

  @@unique([syncAccountId, contactId])
  @@unique([syncAccountId, remoteHref])
  @@unique([syncAccountId, remoteUid])
  @@index([contactId, updatedAt])
  @@index([syncAccountId, tombstonedAt])
}

model SyncJob {
  id             String         @id @default(cuid())
  syncAccountId  String
  status         SyncJobStatus  @default(QUEUED)
  trigger        SyncJobTrigger @default(MANUAL)
  syncDirection  SyncDirection
  attemptCount   Int            @default(0)
  maxAttempts    Int            @default(5)
  nextRetryAt    DateTime?
  leaseExpiresAt DateTime?
  workerId       String?
  idempotencyKey String?
  cursorBefore   String?
  cursorAfter    String?
  createdCount   Int            @default(0)
  updatedCount   Int            @default(0)
  deletedCount   Int            @default(0)
  conflictCount  Int            @default(0)
  skippedCount   Int            @default(0)
  errorCode      String?
  errorSummary   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  syncAccount    SyncAccount    @relation(fields: [syncAccountId], references: [id], onDelete: Cascade)

  @@unique([syncAccountId, idempotencyKey])
  @@index([syncAccountId, status, createdAt])
  @@index([status, nextRetryAt])
}

model SyncConflict {
  id                 String                  @id @default(cuid())
  syncAccountId      String?
  syncContactLinkId  String?
  contactId          String?
  appPasswordId      String?
  conflictType       SyncConflictType
  conflictSource     SyncConflictSource      @default(OUTBOUND_SYNC)
  status             SyncConflictStatus      @default(OPEN)
  resolutionStrategy SyncResolutionStrategy?
  localSyncVersion   Int?
  remoteETag         String?
  localSnapshot      Json?
  remoteSnapshot     Json?
  resolutionNotes    String?
  lastErrorAt        DateTime?
  lastErrorCode      String?
  detectedAt         DateTime                @default(now())
  resolvedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  syncAccount        SyncAccount?            @relation(fields: [syncAccountId], references: [id], onDelete: Cascade)
  syncContactLink    SyncContactLink?        @relation(fields: [syncContactLinkId], references: [id], onDelete: SetNull)
  contact            Contact?                @relation(fields: [contactId], references: [id], onDelete: SetNull)
  appPassword        AppPassword?            @relation(fields: [appPasswordId], references: [id], onDelete: SetNull)

  @@index([syncAccountId, status, detectedAt])
  @@index([contactId, status])
  @@index([syncContactLinkId, status])
  @@index([appPasswordId, status])
  @@index([conflictSource, status, detectedAt])
}

enum EventType {
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_ARCHIVED
  CONTACT_RESTORED
  CONTACT_DELETED
  CONTACT_MERGED
  CONTACT_MERGE_UNDONE
  CONTACT_IMPORTED
  CONTACT_SHARED
  CONTACT_SHARE_RECEIVED
  SYNC_PULLED
  SYNC_PUSHED
  SYNC_CONFLICT_DETECTED
  SYNC_CONFLICT_RESOLVED
}

enum Actor {
  USER
  SYNC
  IMPORT
  SHARE
  FAMILY_MEMBER
  TEAM_MEMBER
  SYSTEM
}

model ActivityEvent {
  id          String    @id @default(cuid())
  userId      String
  contactId   String?
  eventType   EventType
  actor       Actor
  actorDetail String?
  payload     Json      @default("{}")
  createdAt   DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([contactId, createdAt(sort: Desc)])
}

// --- Group scaffolding (P11-02) ------------------------------------------------
// Empty structural models for Family/Teams shared books. No product logic yet —
// Phases 13 (Family) and 14 (Teams) build the behaviour on top of these.

model Group {
  id               String             @id @default(cuid())
  ownerId          String
  type             GroupType
  name             String
  subscriptionId   String?
  memberSlotsLimit Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  owner            User               @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  subscription     Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  members          GroupMember[]
  addressBooks     GroupAddressBook[]

  @@index([ownerId])
  @@index([subscriptionId])
}

model GroupMember {
  id           String            @id @default(cuid())
  groupId      String
  userId       String
  role         GroupRole         @default(MEMBER)
  inviteStatus GroupInviteStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  group        Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, inviteStatus])
}

model GroupAddressBook {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}
