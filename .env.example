# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Public origin — used for CardDAV server URL and contact share links.
# Set this in production so the correct scheme is shown regardless of
# reverse-proxy header forwarding. Example: https://kontax.vexon.co
# APP_URL=""

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: npx auth secret
AUTH_SECRET=""

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/kontax"

# ─── App ─────────────────────────────────────────────────────────────────────
# Public origin — used for CardDAV URLs, share links, email CTAs.
# APP_URL="https://kontax.example.com"

# ─── Rate limiting — self-hosted Valkey (P18-10) ─────────────────────────────
# Falls back to in-memory store in dev if unset (not shared across instances).
# REDIS_URL="redis://192.168.x.x:6379"

# ─── Blob storage — self-hosted MinIO (P18-01) ───────────────────────────────
# Required for avatar file uploads. Falls back to URL-input-only mode if unset.
# MINIO_ENDPOINT="https://minio.yourdomain.com"
# MINIO_ACCESS_KEY=""
# MINIO_SECRET_KEY=""
# MINIO_BUCKET="kontax-uploads"
# MINIO_PUBLIC_URL="https://minio.yourdomain.com/kontax-uploads"

# ─── TOTP encryption — P18-07 ────────────────────────────────────────────────
# Required in production. Generate: openssl rand -hex 32
# TOTP_ENCRYPTION_KEY=""

# ─── Cron jobs — P18-10 ──────────────────────────────────────────────────────
# Sent as x-cron-secret header by LXC cron curl calls. Generate: openssl rand -hex 32
# CRON_SECRET=""

# ─── OAuth providers — deferred to TBD (P18-08) ──────────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# APPLE_CLIENT_ID=""
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_PRIVATE_KEY=""

# ─── Transactional email — Amazon SES (Phase 20) ─────────────────────────────
# Leave empty in dev — emails log to console.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_SES_REGION=""
# EMAIL_FROM=""

# ─── Stripe Customer Portal — configure in Stripe dashboard ─────────────────
# Settings > Billing > Customer portal. Required settings:
#   - Update payment methods: ✓
#   - View invoice history: ✓
#   - Cancel subscriptions: ✓ (cancel at end of period, not immediately)
#   - Update subscriptions (plan changes): ✓ — set allowed prices
#   - Return URL: {APP_URL}/settings?portal=returned

# ─── Stripe billing — Phase 19 ───────────────────────────────────────────────
# All optional in dev — billing features fail gracefully when unset.
# Get these from the Stripe dashboard: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# Get webhook secret by running: stripe listen --print-secret
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from Stripe dashboard > Products > Pricing
# STRIPE_PRICE_ID_PRO_MONTHLY="price_..."
# STRIPE_PRICE_ID_PRO_YEARLY="price_..."
# STRIPE_PRICE_ID_FAMILY_MONTHLY="price_..."
# STRIPE_PRICE_ID_FAMILY_YEARLY="price_..."
# STRIPE_PRICE_ID_TEAMS_MONTHLY="price_..."
# STRIPE_PRICE_ID_TEAMS_YEARLY="price_..."
# Promo codes: no env var needed — enable in Stripe dashboard > Promotions and
# set allow_promotion_codes: true in checkout (already set). Codes are
# validated entirely by Stripe.
# Display prices shown on the pricing page (public — no secrets here)
# NEXT_PUBLIC_PRICE_PRO_MONTHLY="£8"
# NEXT_PUBLIC_PRICE_PRO_YEARLY="£77"
# NEXT_PUBLIC_PRICE_FAMILY_MONTHLY="£14"
# NEXT_PUBLIC_PRICE_FAMILY_YEARLY="£134"
# NEXT_PUBLIC_PRICE_TEAMS_MONTHLY="£12"
# NEXT_PUBLIC_PRICE_TEAMS_YEARLY="£115"
